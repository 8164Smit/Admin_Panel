<div class="row justify-content-center">
  <div class="col-lg-9">
    <div class="card">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-pencil-square me-2"></i>Edit Product</h2>
        <a href="/product" class="btn btn-outline btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
      </div>
      <div class="card-body">
        <form method="POST" action="/product/edit/<%= product._id %>" enctype="multipart/form-data">

          <div style="background:#f8fafc;border-radius:10px;padding:20px;margin-bottom:20px;">
            <h3 style="font-size:14px;font-weight:700;color:#1e293b;margin-bottom:16px;"><i class="bi bi-diagram-3 me-2" style="color:#667eea;"></i>Category Relationships</h3>
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">Category <span style="color:#ef4444;">*</span></label>
                <select id="categorySelect" name="category" class="form-select" required>
                  <option value="">-- Select Category --</option>
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat._id %>" <%= product.category && product.category.toString() === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Subcategory <span style="color:#ef4444;">*</span></label>
                <select id="subcategorySelect" name="subcategory" class="form-select" required>
                  <% subcategories.forEach(sub => { %>
                    <option value="<%= sub._id %>" <%= product.subcategory && product.subcategory.toString() === sub._id.toString() ? 'selected' : '' %>><%= sub.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Extra Category</label>
                <select id="extraCategorySelect" name="extraCategory" class="form-select">
                  <option value="">-- None --</option>
                  <% extraCategories.forEach(ex => { %>
                    <option value="<%= ex._id %>" <%= product.extraCategory && product.extraCategory.toString() === ex._id.toString() ? 'selected' : '' %>><%= ex.name %></option>
                  <% }) %>
                </select>
              </div>
            </div>
          </div>

          <div style="background:#f8fafc;border-radius:10px;padding:20px;margin-bottom:20px;">
            <h3 style="font-size:14px;font-weight:700;color:#1e293b;margin-bottom:16px;"><i class="bi bi-info-circle me-2" style="color:#667eea;"></i>Basic Information</h3>
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label">Product Name <span style="color:#ef4444;">*</span></label>
                <input type="text" name="name" class="form-control" value="<%= product.name %>" required>
              </div>
              <div class="col-md-4">
                <label class="form-label">Brand</label>
                <input type="text" name="brand" class="form-control" value="<%= product.brand %>">
              </div>
              <div class="col-md-4">
                <label class="form-label">SKU</label>
                <input type="text" name="sku" class="form-control" value="<%= product.sku || '' %>">
              </div>
              <div class="col-md-4">
                <label class="form-label">Price ($) <span style="color:#ef4444;">*</span></label>
                <input type="number" name="price" class="form-control" value="<%= product.price %>" min="0" step="0.01" required>
              </div>
              <div class="col-md-2">
                <label class="form-label">Discount (%)</label>
                <input type="number" name="discount" class="form-control" value="<%= product.discount %>" min="0" max="100">
              </div>
              <div class="col-md-2">
                <label class="form-label">Stock</label>
                <input type="number" name="stock" class="form-control" value="<%= product.stock %>" min="0">
              </div>
            </div>
          </div>

          <div style="background:#f8fafc;border-radius:10px;padding:20px;margin-bottom:20px;">
            <h3 style="font-size:14px;font-weight:700;color:#1e293b;margin-bottom:16px;"><i class="bi bi-text-paragraph me-2" style="color:#667eea;"></i>Details</h3>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="4"><%= product.description %></textarea>
              </div>
              <div class="col-12">
                <label class="form-label">Features</label>
                <textarea name="features" class="form-control" rows="3"><%= product.features %></textarea>
              </div>
            </div>
          </div>

          <div style="background:#f8fafc;border-radius:10px;padding:20px;margin-bottom:20px;">
            <h3 style="font-size:14px;font-weight:700;color:#1e293b;margin-bottom:16px;"><i class="bi bi-images me-2" style="color:#667eea;"></i>Images</h3>

            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Main Image</label>
                <% if (product.mainImage) { %>
                  <div class="mb-2"><img src="/uploads/<%= product.mainImage %>" alt="Main" class="img-preview"></div>
                <% } %>
                <input type="file" name="mainImage" class="form-control image-input-preview" data-preview="mainImgPreview" accept="image/*">
                <img id="mainImgPreview" alt="Preview" class="img-preview mt-2" style="display:none;">
              </div>

              <div class="col-md-6">
                <label class="form-label">Additional Images</label>
                <% if (product.images && product.images.length > 0) { %>
                  <div class="product-images-grid mb-2">
                    <% product.images.forEach(img => { %>
                      <div class="product-img-item">
                        <img src="/uploads/<%= img %>" alt="">
                        <label>
                          <input type="checkbox" name="deleteImages" value="<%= img %>" style="display:none;" class="delete-img-check">
                          <button type="button" class="img-delete-btn" onclick="this.previousElementSibling.checked=true;this.closest('.product-img-item').style.opacity='0.3';" title="Mark for deletion">
                            <i class="bi bi-x"></i>
                          </button>
                        </label>
                      </div>
                    <% }) %>
                  </div>
                  <p class="form-text"><i class="bi bi-info-circle me-1"></i>Click × to mark images for deletion.</p>
                <% } %>
                <input type="file" name="images" class="form-control" accept="image/*" multiple>
                <p class="form-text">Add more images (max 10).</p>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Status</label>
            <div style="display:flex;gap:16px;">
              <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13.5px;"><input type="radio" name="status" value="active" <%= product.status === 'active' ? 'checked' : '' %> style="accent-color:#667eea;"> Active</label>
              <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13.5px;"><input type="radio" name="status" value="inactive" <%= product.status === 'inactive' ? 'checked' : '' %> style="accent-color:#667eea;"> Inactive</label>
            </div>
          </div>

          <div style="display:flex;gap:10px;">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Update Product</button>
            <a href="/product" class="btn btn-outline">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

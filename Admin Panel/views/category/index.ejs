<div class="card">
  <div class="card-header">
    <h2 class="card-title"><i class="bi bi-tag me-2"></i>All Categories <span style="font-size:13px;font-weight:500;color:#94a3b8;">(<%= total %>)</span></h2>
    <a href="/category/add" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Add Category</a>
  </div>

  <div style="padding:16px 20px;border-bottom:1px solid #e2e8f0;">
    <form method="GET" action="/category" class="table-toolbar">
      <div class="search-input-wrapper">
        <i class="bi bi-search"></i>
        <input type="text" name="search" class="search-input" placeholder="Search categories..." value="<%= search %>">
      </div>
      <select name="status" class="filter-select">
        <option value="">All Status</option>
        <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
        <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>Inactive</option>
      </select>
      <select name="sort" class="filter-select">
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest</option>
        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
        <option value="az" <%= sort === 'az' ? 'selected' : '' %>>A → Z</option>
        <option value="za" <%= sort === 'za' ? 'selected' : '' %>>Z → A</option>
      </select>
      <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel"></i> Filter</button>
      <a href="/category" class="btn btn-outline btn-sm"><i class="bi bi-x-circle"></i> Clear</a>
    </form>
  </div>

  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Image</th>
          <th>Name</th>
          <th>Slug</th>
          <th>Description</th>
          <th>Status</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (categories.length === 0) { %>
          <tr>
            <td colspan="8" style="text-align:center;padding:40px;color:#94a3b8;">
              <i class="bi bi-inbox" style="font-size:32px;display:block;margin-bottom:10px;"></i>
              No categories found
            </td>
          </tr>
        <% } %>
        <% categories.forEach((cat, i) => { %>
          <tr>
            <td><span style="font-size:12px;color:#94a3b8;font-weight:600;"><%= ((currentPage - 1) * 10) + i + 1 %></span></td>
            <td>
              <% if (cat.image) { %>
                <img src="/uploads/<%= cat.image %>" alt="<%= cat.name %>" class="img-thumbnail-sm">
              <% } else { %>
                <div style="width:44px;height:44px;background:#f1f5f9;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:18px;">
                  <i class="bi bi-image"></i>
                </div>
              <% } %>
            </td>
            <td><span style="font-weight:600;color:#1e293b;"><%= cat.name %></span></td>
            <td><code style="font-size:12px;background:#f1f5f9;padding:3px 7px;border-radius:4px;color:#667eea;"><%= cat.slug %></code></td>
            <td><span style="font-size:12.5px;color:#64748b;"><%= cat.description ? cat.description.substring(0, 50) + (cat.description.length > 50 ? '...' : '') : '—' %></span></td>
            <td>
              <div style="display:flex;align-items:center;gap:8px;">
                <label class="toggle-switch">
                  <input type="checkbox" class="status-toggle" data-id="<%= cat._id %>" data-url="/category/toggle-status/<%= cat._id %>" <%= cat.status === 'active' ? 'checked' : '' %>>
                  <span class="toggle-slider"></span>
                </label>
                <span class="status-badge <%= cat.status %>" id="badge-<%= cat._id %>"><%= cat.status %></span>
              </div>
            </td>
            <td><span style="font-size:12px;color:#94a3b8;"><%= new Date(cat.createdAt).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'}) %></span></td>
            <td>
              <div style="display:flex;gap:4px;">
                <a href="/category/edit/<%= cat._id %>" class="btn btn-warning btn-sm btn-icon" title="Edit">
                  <i class="bi bi-pencil"></i>
                </a>
                <form method="POST" action="/category/delete/<%= cat._id %>" class="delete-form" data-name="<%= cat.name %>">
                  <button type="submit" class="btn btn-danger btn-sm btn-icon" title="Delete">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
    <div class="pagination-wrapper">
      <span class="pagination-info">Showing <%= ((currentPage - 1) * 10) + 1 %>–<%= Math.min(currentPage * 10, total) %> of <%= total %></span>
      <div class="pagination">
        <a href="/category?page=<%= currentPage - 1 %>&search=<%= search %>&sort=<%= sort %>&status=<%= status %>"
          class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>"><i class="bi bi-chevron-left"></i></a>
        <% for (let p = 1; p <= totalPages; p++) { %>
          <a href="/category?page=<%= p %>&search=<%= search %>&sort=<%= sort %>&status=<%= status %>"
            class="page-link <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
        <% } %>
        <a href="/category?page=<%= currentPage + 1 %>&search=<%= search %>&sort=<%= sort %>&status=<%= status %>"
          class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>"><i class="bi bi-chevron-right"></i></a>
      </div>
    </div>
  <% } %>
</div>

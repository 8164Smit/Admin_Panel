<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-plus-circle me-2"></i>Add Category</h2>
        <a href="/category" class="btn btn-outline btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
      </div>
      <div class="card-body">
        <form method="POST" action="/category/add" enctype="multipart/form-data">
          <div class="form-group">
            <label class="form-label" for="catName">Category Name <span style="color:#ef4444;">*</span></label>
            <input type="text" id="catName" name="name" class="form-control" placeholder="e.g. Electronics" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="catDesc">Description</label>
            <textarea id="catDesc" name="description" class="form-control" rows="3" placeholder="Brief description of this category..."></textarea>
          </div>
          <div class="form-group">
            <label class="form-label" for="catImage">Category Image</label>
            <input type="file" id="catImage" name="image" class="form-control image-input-preview" data-preview="catImagePreview" accept="image/*">
            <p class="form-text">Accepted: JPG, PNG, GIF, WEBP. Max 5MB.</p>
            <img id="catImagePreview" alt="Preview" class="img-preview mt-2" style="display:none;">
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <div style="display:flex;gap:16px;">
              <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13.5px;">
                <input type="radio" name="status" value="active" checked style="accent-color:#667eea;"> Active
              </label>
              <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13.5px;">
                <input type="radio" name="status" value="inactive" style="accent-color:#667eea;"> Inactive
              </label>
            </div>
          </div>
          <div style="display:flex;gap:10px;">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Save Category</button>
            <a href="/category" class="btn btn-outline">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

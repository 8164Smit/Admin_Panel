<div class="row g-3 mb-4">
  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-icon purple"><i class="bi bi-tag-fill"></i></div>
      <div class="stat-info">
        <div class="stat-label">Categories</div>
        <div class="stat-value"><%= totalCategories %></div>
        <div class="stat-sub"><%= activeCategories %> active</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-icon green"><i class="bi bi-tags-fill"></i></div>
      <div class="stat-info">
        <div class="stat-label">Subcategories</div>
        <div class="stat-value"><%= totalSubcategories %></div>
        <div class="stat-sub">Across all categories</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-icon orange"><i class="bi bi-diagram-3-fill"></i></div>
      <div class="stat-info">
        <div class="stat-label">Extra Categories</div>
        <div class="stat-value"><%= totalExtraCategories %></div>
        <div class="stat-sub">Third-level taxonomy</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-icon blue"><i class="bi bi-box-seam-fill"></i></div>
      <div class="stat-info">
        <div class="stat-label">Products</div>
        <div class="stat-value"><%= totalProducts %></div>
        <div class="stat-sub"><%= activeProducts %> active</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-lg-8">
    <div class="card h-100">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-bar-chart-fill me-2" style="color:#667eea;"></i>Overview</h2>
      </div>
      <div class="card-body">
        <div class="chart-container">
          <canvas id="overviewChart"></canvas>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card h-100">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-pie-chart-fill me-2" style="color:#f59e0b;"></i>Product Status</h2>
      </div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <div class="chart-container" style="height:200px;width:200px;">
          <canvas id="statusChart"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-7">
    <div class="card">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-box-seam me-2" style="color:#10b981;"></i>Latest Products</h2>
        <a href="/product" class="btn btn-outline btn-sm">View All</a>
      </div>
      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Product</th>
              <th>Category</th>
              <th>Price</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentProducts.length === 0) { %>
              <tr><td colspan="5" style="text-align:center;color:#94a3b8;padding:30px;">No products yet</td></tr>
            <% } %>
            <% recentProducts.forEach((p, i) => { %>
              <tr>
                <td><span style="font-size:12px;color:#94a3b8;font-weight:600;"><%= i+1 %></span></td>
                <td>
                  <div style="display:flex;align-items:center;gap:10px;">
                    <% if (p.mainImage) { %>
                      <img src="/uploads/<%= p.mainImage %>" alt="" class="img-thumbnail-sm">
                    <% } else { %>
                      <div style="width:44px;height:44px;background:#f1f5f9;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#94a3b8;">
                        <i class="bi bi-image"></i>
                      </div>
                    <% } %>
                    <div>
                      <div style="font-weight:600;font-size:13px;"><%= p.name %></div>
                      <div style="font-size:11px;color:#94a3b8;">SKU: <%= p.sku || 'N/A' %></div>
                    </div>
                  </div>
                </td>
                <td><span style="font-size:12.5px;color:#64748b;"><%= p.category ? p.category.name : 'N/A' %></span></td>
                <td><span style="font-weight:700;color:#667eea;">$<%= p.price %></span></td>
                <td><span class="status-badge <%= p.status %>"><%= p.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-activity me-2" style="color:#ef4444;"></i>Recent Activities</h2>
      </div>
      <div class="card-body" style="padding:0 20px;">
        <% if (recentActivities.length === 0) { %>
          <div style="text-align:center;color:#94a3b8;padding:30px;font-size:13px;">No recent activities</div>
        <% } %>
        <% recentActivities.forEach(act => { %>
          <div class="activity-item">
            <div class="activity-icon <%= act.color %>">
              <i class="bi <%= act.icon %>"></i>
            </div>
            <div class="activity-content">
              <div class="activity-title"><%= act.action %> <%= act.entity %>: <strong><%= act.entityName %></strong></div>
              <div class="activity-meta">
                <i class="bi bi-clock me-1"></i>
                <%= new Date(act.createdAt).toLocaleString('en-IN', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<script>
  const overviewCtx = document.getElementById('overviewChart').getContext('2d');
  new Chart(overviewCtx, {
    type: 'bar',
    data: {
      labels: ['Categories', 'Subcategories', 'Extra Categories', 'Products'],
      datasets: [{
        label: 'Total Count',
        data: [<%= totalCategories %>, <%= totalSubcategories %>, <%= totalExtraCategories %>, <%= totalProducts %>],
        backgroundColor: ['rgba(102,126,234,0.8)', 'rgba(16,185,129,0.8)', 'rgba(245,158,11,0.8)', 'rgba(59,130,246,0.8)'],
        borderRadius: 8,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { stepSize: 1 } },
        x: { grid: { display: false } }
      }
    }
  });

  const statusCtx = document.getElementById('statusChart').getContext('2d');
  new Chart(statusCtx, {
    type: 'doughnut',
    data: {
      labels: ['Active', 'Inactive'],
      datasets: [{
        data: [<%= activeProducts %>, <%= inactiveProducts %>],
        backgroundColor: ['#10b981', '#e2e8f0'],
        borderWidth: 0,
        hoverOffset: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '72%',
      plugins: {
        legend: { position: 'bottom', labels: { padding: 16, font: { size: 12, family: 'Inter' } } }
      }
    }
  });
</script>

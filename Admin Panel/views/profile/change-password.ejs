<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header">
        <h2 class="card-title"><i class="bi bi-shield-lock me-2"></i>Change Password</h2>
        <a href="/profile" class="btn btn-outline btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
      </div>
      <div class="card-body">
        <form method="POST" action="/profile/change-password">
          <div class="form-group">
            <label class="form-label" for="oldPwd">Current Password</label>
            <input type="password" id="oldPwd" name="oldPassword" class="form-control" required placeholder="Enter current password">
          </div>
          <div class="form-group">
            <label class="form-label" for="newPwd">New Password</label>
            <input type="password" id="newPwd" name="newPassword" class="form-control" required placeholder="Min 6 characters" minlength="6">
          </div>
          <div class="form-group">
            <label class="form-label" for="confirmPwd">Confirm New Password</label>
            <input type="password" id="confirmPwd" name="confirmPassword" class="form-control" required placeholder="Repeat new password" minlength="6">
          </div>
          <button type="submit" class="btn btn-primary"><i class="bi bi-shield-check"></i> Update Password</button>
        </form>
      </div>
    </div>
  </div>
</div>

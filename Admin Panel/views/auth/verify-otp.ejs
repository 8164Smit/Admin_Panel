<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify OTP | Admin Panel</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-logo" style="background:linear-gradient(135deg,#43e97b,#38f9d7);"><i class="bi bi-shield-check"></i></div>
    <h1 class="auth-title">Verify OTP</h1>
    <p class="auth-sub">Enter the 6-digit OTP sent to your email</p>

    <% if (error && error.length > 0) { %>
      <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:12px 14px;margin-bottom:18px;font-size:13px;color:#dc2626;display:flex;align-items:center;gap:8px;">
        <i class="bi bi-exclamation-circle-fill"></i> <%= error[0] %>
      </div>
    <% } %>
    <% if (success && success.length > 0) { %>
      <div style="background:#d1fae5;border:1px solid #6ee7b7;border-radius:8px;padding:12px 14px;margin-bottom:18px;font-size:13px;color:#065f46;display:flex;align-items:center;gap:8px;">
        <i class="bi bi-check-circle-fill"></i> <%= success[0] %>
      </div>
    <% } %>

    <form method="POST" action="/auth/verify-otp">
      <div class="form-group">
        <label class="form-label" for="otpInput">OTP Code</label>
        <input type="text" id="otpInput" name="otp" class="form-control" maxlength="6" pattern="\d{6}" placeholder="Enter 6-digit OTP" required
          style="font-size:22px;letter-spacing:10px;text-align:center;font-weight:700;">
        <p class="form-text"><i class="bi bi-clock me-1"></i>OTP expires in 10 minutes</p>
      </div>
      <button type="submit" class="btn btn-primary w-100" style="padding:12px;font-size:14px;justify-content:center;">
        <i class="bi bi-check2-circle"></i> Verify OTP
      </button>
    </form>
    <div style="text-align:center;margin-top:20px;">
      <a href="/auth/forgot-password" style="font-size:13px;color:#667eea;"><i class="bi bi-arrow-repeat me-1"></i>Resend OTP</a>
    </div>
  </div>
</div>
</body>
</html>
